# ============================================
# Nukleo Digital - Variables d'environnement
# ============================================
# Copiez ce fichier vers .env et remplissez les valeurs
# cp .env.example .env

# ============================================
# Base de données
# ============================================
# URL de connexion PostgreSQL (format: postgresql://user:password@host:port/database)
DATABASE_URL=postgresql://user:password@localhost:5432/nukleo_digital

# ============================================
# Sécurité & Authentification
# ============================================
# Secret JWT pour les sessions et tokens (générez une chaîne aléatoire sécurisée)
JWT_SECRET=your-secret-jwt-key-change-this-in-production

# Google OAuth pour l'authentification admin
# Créez une application sur https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optionnel : l'app utilise BASE_URL pour construire le callback. Sans BASE_URL, défaut = http://localhost:3000
# GOOGLE_CALLBACK_URL est ignoré ; le callback est toujours BASE_URL + /api/auth/google/callback

# Emails autorisés à se connecter à l'admin (séparés par des virgules)
ADMIN_ALLOWED_EMAILS=clement@nukleo.com

# URL publique du site (obligatoire en staging/prod pour que Google OAuth fonctionne)
# Ex. staging: https://ingenious-rebirth-production-7f81.up.railway.app
# Ex. prod: https://nukleo.digital
BASE_URL=http://localhost:3000

# ============================================
# Manus OAuth (Espace client)
# ============================================
# ID de l'application Manus
VITE_APP_ID=your-manus-app-id
# URL du serveur OAuth Manus
OAUTH_SERVER_URL=https://api.manus.im
# URL du portail OAuth Manus
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
# ID du propriétaire (owner)
OWNER_OPEN_ID=your-owner-open-id
# Nom du propriétaire
OWNER_NAME=Your Name

# ============================================
# Built-in Forge API
# ============================================
# URL de l'API Forge
BUILT_IN_FORGE_API_URL=https://forge-api.example.com
# Clé API Forge (backend)
BUILT_IN_FORGE_API_KEY=your-forge-api-key
# Clé API Forge (frontend)
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key
# URL de l'API Forge (frontend)
VITE_FRONTEND_FORGE_API_URL=https://forge-api.example.com

# ============================================
# Analytics
# ============================================
# Endpoint pour les analytics
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com/api
# ID du site web pour analytics
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================
# Application
# ============================================
# Titre de l'application
VITE_APP_TITLE=Nukleo Digital
# URL du logo de l'application
VITE_APP_LOGO=https://nukleo.digital/logo.png

# ============================================
# Sentry (Monitoring d'erreurs)
# ============================================
# DSN Sentry pour le monitoring backend (optionnel)
SENTRY_DSN=
# DSN Sentry pour le monitoring frontend (optionnel)
VITE_SENTRY_DSN=
# Environnement Sentry
SENTRY_ENVIRONMENT=development

# ============================================
# Cloudflare R2 (Stockage vidéo Union + PDF communiqué de presse)
# ============================================
# Si toutes les variables R2 sont définies, les uploads vont sur R2 (bucket privé).
# URLs présignées pour l'accès temporaire — pas de R2_PUBLIC_URL requis.
# Créez un bucket R2 sur https://dash.cloudflare.com → R2 → Create bucket
# Puis : Manage R2 API Tokens → Create API token (Object Read & Write)
# Configurez CORS sur le bucket pour autoriser l'origine de votre site.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ============================================
# AWS S3 (Stockage de fichiers)
# ============================================
# Clés d'accès AWS S3 (optionnel, si utilisé)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# ============================================
# SendGrid (Emails)
# ============================================
# Clé API SendGrid pour l'envoi d'emails (optionnel)
SENDGRID_API_KEY=

# ============================================
# Plateforme Interne (HUB.Nukleo)
# ============================================
# URL de la plateforme interne pour récupérer les témoignages
INTERNAL_PLATFORM_URL=https://nukleohub-production.up.railway.app
# Clé API pour l'authentification avec la plateforme interne
INTERNAL_PLATFORM_API_KEY=nk_40b933b07bcac5e8997104397f16950bf05b8f75b2c76ba2d31c210b0a90ca12

# ============================================
# Environnement
# ============================================
# Environnement d'exécution (development, production, test)
NODE_ENV=development
# Port du serveur (par défaut: 3000)
PORT=3000

