# Dockerfile to regenerate pnpm-lock.yaml with pnpm 10.4.1
FROM node:20.20.0

WORKDIR /app

# Install corepack and pnpm 10.4.1
RUN npm install -g corepack@latest && \
    corepack enable && \
    corepack prepare pnpm@10.4.1 --activate

# Copy package files
COPY package.json pnpm-lock.yaml* ./

# Regenerate lockfile
RUN rm -f pnpm-lock.yaml && \
    pnpm install --lockfile-only

# The lockfile will be in /app/pnpm-lock.yaml
# Run with: docker run --rm -v ${PWD}:/output $(docker build -q -f Dockerfile.lockfile .) cp /app/pnpm-lock.yaml /output/
